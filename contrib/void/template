# Template file for 'honey'
#
# Copy this to a void-packages checkout as srcpkgs/honey/template, then:
#   ./xbps-src pkg honey
#   xbps-install --repository=hostdir/binpkgs honey
#
# At release time set `version` to the tag (without the leading v) and refresh
# `checksum` with:  xbps-src fetch  &&  xbps-src -c update-check  (or compute
# sha256 of the release tarball). The wlroots pin is `wlroots0.20-devel`; when
# honey retargets wlroots 0.21, bump the major/minor and swap to wlroots0.21-devel.
pkgname=honey
version=0.20.4
revision=1
build_style=gnu-makefile
make_install_args="PREFIX=/usr"
hostmakedepends="pkg-config wayland-devel"
makedepends="wlroots0.20-devel wayland-devel libxkbcommon-devel pixman-devel
 libinput-devel libdrm-devel libxcb-devel xcb-util-wm-devel"
depends="xorg-server-xwayland"
short_desc="Tiling Wayland compositor on wlroots (master-stack, dynamic config)"
maintainer="Maxence Hamel <dev@maxencehamel.com>"
license="GPL-3.0-or-later"
homepage="https://github.com/l3mah/honey-wm"
distfiles="https://github.com/l3mah/honey-wm/archive/refs/tags/v${version}.tar.gz"
checksum=@REPLACE_WITH_SHA256_OF_THE_RELEASE_TARBALL@

post_install() {
	vlicense LICENSE
}
